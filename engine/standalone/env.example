# Copy to .env and fill in. Never commit the filled-in copy.

# Required. Get one from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Confidence at or above which a plan skips the human gate. Only consulted
# when ALWAYS_ASK is false.
CONFIDENCE_THRESHOLD=0.8

# Pause for approval on every run regardless of confidence. Start here. Turn it
# off only once you have watched enough runs to trust the threshold.
ALWAYS_ASK=true
