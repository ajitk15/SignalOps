# SignalAIOps production environment. Copy to `.env` and fill in.
# Never commit the filled-in copy.

# --- Required -----------------------------------------------------------------

# Marks this as a real deployment. Two effects:
#   - the session cookie is set Secure, so it is only sent over HTTPS
#     (which is why you want the Caddy service, or your own TLS proxy);
#   - the server refuses to start unless the auth provider verifies identity,
#     which the password provider does — so this is safe to set.
SIGNALOPS_ENV=production

# The first administrator. Created and re-asserted on every start, so this file
# is also the recovery path if admin access is lost. At least 10 characters.
SIGNALOPS_ADMIN_EMAIL=admin@yourcompany.com
SIGNALOPS_ADMIN_PASSWORD=change-this-to-a-long-passphrase

# Enables the public "Request access" form. Submissions remain pending until an
# administrator approves them and assigns a role in Users.
SIGNALOPS_REGISTRATION_ENABLED=false

# Password recovery uses a one-time email link. Set the public HTTPS origin and
# your mail provider's SMTP values; omit SMTP credentials only when the server
# permits trusted unauthenticated relay.
SIGNALOPS_PUBLIC_URL=https://signalaiops.com
SIGNALOPS_PASSWORD_RESET_TTL_MINUTES=15
SIGNALOPS_SMTP_HOST=
SIGNALOPS_SMTP_PORT=587
SIGNALOPS_SMTP_USERNAME=
SIGNALOPS_SMTP_PASSWORD=
SIGNALOPS_SMTP_FROM=
SIGNALOPS_SMTP_STARTTLS=true
SIGNALOPS_SMTP_SSL=false

# Signs session cookies. Generate once and keep it: changing it logs everyone
# out. `openssl rand -hex 32`
SIGNALOPS_SESSION_SECRET=

# Encrypts the ServiceNow / Jira credentials stored in the database. Generate
# once and BACK IT UP: losing it makes every stored connection secret
# unreadable. `openssl rand -hex 32`
SIGNALOPS_SECRET_KEY=

# --- Strongly recommended -----------------------------------------------------

# Without a real key the platform runs in simulated mode: workflows execute end
# to end but every agent result is placeholder text. Get one from
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Optional -----------------------------------------------------------------

# Session lifetime in seconds. Default 12 hours.
# SIGNALOPS_SESSION_MAX_AGE=43200

# How many workflow runs may execute at once.
# SIGNALOPS_MAX_CONCURRENT_RUNS=4

# ServiceNow / Jira connections are configured in the UI (Connections) and
# stored encrypted, so credentials do NOT belong here. The environment-variable
# ServiceNow path still works as a fallback if you prefer it — see .env.example.
