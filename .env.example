# Copy this file to .env for local use. Never commit the real .env file.
# The current application reads process environment variables; load this file
# in your shell or with your preferred dotenv launcher before starting it.

# -----------------------------------------------------------------------------
# Runtime switches — safe, zero-AI defaults
# -----------------------------------------------------------------------------
ENABLE_MQ_ACE_COLLECTOR=true
ENABLE_INCIDENT_AI=false
ENABLE_LEGACY_AI_WATCHER=false

# -----------------------------------------------------------------------------
# MQ / ACE MCP server — read-only endpoint on port 8010
# -----------------------------------------------------------------------------
MQ_MCP_URL=https://127.0.0.1:8010/mcp
MQ_MCP_HOST=127.0.0.1
MQ_MCP_AUTH_USER=
MQ_MCP_AUTH_PASSWORD=
MQ_MCP_TLS_CERT=

# -----------------------------------------------------------------------------
# AI investigation — required only when ENABLE_INCIDENT_AI=true
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# -----------------------------------------------------------------------------
# Splunk historical context — use a read-only search token
# Leave blank to disable this integration.
# -----------------------------------------------------------------------------
SPLUNK_BASE_URL=
SPLUNK_TOKEN=

# -----------------------------------------------------------------------------
# Dynatrace historical context — use a token with problems.read only
# Leave blank to disable this integration.
# -----------------------------------------------------------------------------
DYNATRACE_BASE_URL=
DYNATRACE_TOKEN=
