# Copy this file to .env for local use. Never commit the real .env file.
# The current application reads process environment variables; load this file
# in your shell or with your preferred dotenv launcher before starting it.

# -----------------------------------------------------------------------------
# Runtime switches — safe, zero-AI defaults
# -----------------------------------------------------------------------------
ENABLE_MQ_ACE_COLLECTOR=true
ENABLE_INCIDENT_AI=false
ENABLE_LEGACY_AI_WATCHER=false

# -----------------------------------------------------------------------------
# MQ / ACE MCP server — read-only endpoint on port 8010
# -----------------------------------------------------------------------------
MQ_MCP_URL=https://127.0.0.1:8010/mcp
MQ_MCP_HOST=127.0.0.1
MQ_MCP_AUTH_USER=
MQ_MCP_AUTH_PASSWORD=
MQ_MCP_TLS_CERT=

# -----------------------------------------------------------------------------
# AI investigation — required only when ENABLE_INCIDENT_AI=true
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# -----------------------------------------------------------------------------
# Splunk historical context — use a read-only search token
# Leave blank to disable this integration.
# -----------------------------------------------------------------------------
SPLUNK_BASE_URL=
SPLUNK_TOKEN=

# -----------------------------------------------------------------------------
# Dynatrace historical context — use a token with problems.read only
# Leave blank to disable this integration.
# -----------------------------------------------------------------------------
DYNATRACE_BASE_URL=
DYNATRACE_TOKEN=

# -----------------------------------------------------------------------------
# ServiceNow — ticket sink (outbox) and change-request context.
# SERVICENOW_MODE: dry_run (default, logs payloads only) | live | off
# Read and write use SEPARATE accounts: reads need change_request/incident
# read; writes need incident create only.
# -----------------------------------------------------------------------------
# SERVICENOW_MODE is no longer read. Dry run is per-workflow configuration
# now, set in the onboarding wizard, so two workflows against the same
# instance can differ — which a single global switch could not express.
# The read and write accounts must have their identity type set to MACHINE on
# the ServiceNow user record. Human accounts are refused for REST basic auth,
# and the 401 is indistinguishable from a wrong password.
SN_INSTANCE_URL=
SN_READ_USER=
SN_READ_PASSWORD=
SN_WRITE_USER=
SN_WRITE_PASSWORD=

# Refuses to start with anything other than "local" while the login is the
# placeholder provider. A deliberate tripwire, not a setting to work around.
SIGNALOPS_ENV=local

# Optional: signs session cookies. A random value is generated per process if
# unset, which logs everyone out on restart.
# SIGNALOPS_SESSION_SECRET=

# ServiceNow OAuth. Optional, and the answer when basic authentication returns
# 401 for the REST API even though the same account signs in at /login.do —
# many instances refuse HTTP Basic for REST while still accepting it for the
# UI, and the two failures are indistinguishable from the outside.
#
# Create these in the instance under:
#   System OAuth -> Application Registry -> New
#   -> "Create an OAuth API endpoint for external clients"
# The username and password above are still used, via the password grant, so
# work notes keep carrying the read or write account in ServiceNow's own audit.
SN_CLIENT_ID=
SN_CLIENT_SECRET=

# --- Administrator ------------------------------------------------------------
# The admin account is configuration, not data: it is created and re-asserted
# from here on every start. Other users are either created directly by this
# administrator or approved from pending access requests in the Users screen.
#
# Re-applied at boot on purpose, so recovering a lost admin password is "edit
# this file and restart" rather than a database surgery procedure.
SIGNALOPS_ADMIN_EMAIL=admin@example.com
SIGNALOPS_ADMIN_PASSWORD=change-this-long-password

# Public access requests are off unless explicitly enabled. A request never
# creates an account: only an administrator can approve it and assign a role.
SIGNALOPS_REGISTRATION_ENABLED=false

# --- Password-reset email ---------------------------------------------------
# Forgot-password links are enabled when PUBLIC_URL, SMTP_HOST and SMTP_FROM
# are all present. The link is one-time use and expires after 15 minutes.
SIGNALOPS_PUBLIC_URL=http://localhost:8000
SIGNALOPS_PASSWORD_RESET_TTL_MINUTES=15
SIGNALOPS_SMTP_HOST=
SIGNALOPS_SMTP_PORT=587
SIGNALOPS_SMTP_USERNAME=
SIGNALOPS_SMTP_PASSWORD=
SIGNALOPS_SMTP_FROM=
SIGNALOPS_SMTP_STARTTLS=true
SIGNALOPS_SMTP_SSL=false

# Encrypts stored connection credentials. Generated next to the database if
# unset — back it up, because losing it makes every saved credential
# unreadable. Intended to move to a vault or KMS; see crypto.py.
# SIGNALOPS_SECRET_KEY=
